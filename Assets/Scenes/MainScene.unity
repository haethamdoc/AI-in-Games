--- !u!114 &337786286
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 337786278}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ec422cd568a9c4a31ad7c36d0572b9da, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  itemId: 5
  indentLevel: 0
  storyText: 'Well hi there! I''m a patrolling NPC. {wc}

    You see, I normally
    patrol between a finite amount of points set by the designers.{wc}

    Otherwise,
    I would a random point within the environment and set it as my destination. {wc}

    As
    you may have noticed, I have two states: Walking and Idle.{wc}

    When you
    step into my trigger, the Idle state is toggled so we can have a conversation,
    otherwise I walk between the points I''m delegated to.'
  description: 
  character: {fileID: 0}
  portrait: {fileID: 0}
  voiceOverClip: {fileID: 0}
  showAlways: 1
  showCount: 1
  extendPrevious: 0
  fadeWhenDone: 1
  waitForClick: 1
  stopVoiceover: 1
  waitForVO: 0
  setSayDialog: {fileID: 0}
